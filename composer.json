{
    "name": "devwebs01/laravel-license-client",
    "description": "Simple licensing client for Laravel applications - license validation, device fingerprinting, offline grace period, and feature flags.",
    "type": "library",
    "keywords": ["laravel", "license", "licensing", "validation", "activation", "device-fingerprinting"],
    "license": "MIT",
    "homepage": "https://github.com/devWebs01/Licensing-Client",
    "support": {
        "issues": "https://github.com/devWebs01/Licensing-Client/issues",
        "source": "https://github.com/devWebs01/Licensing-Client"
    },
    "authors": [
        {
            "name": "DevWebs01",
            "homepage": "https://github.com/devwebs01"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "DevWebs01\\LicensingClient\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DevWebs01\\LicensingClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevWebs01\\LicensingClient\\LicensingClientServiceProvider"
            ],
            "aliases": {
                "LicenseClient": "DevWebs01\\LicensingClient\\Facades\\LicenseClient"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage",
        "lint": "vendor/bin/pint --test",
        "lint-fix": "vendor/bin/pint"
    }
}
